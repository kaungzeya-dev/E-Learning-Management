# Backend Environment Variables Template
#
# Option A — Create `backend/.env.local` with Java property keys (`spring.datasource.url=...`).
# Spring loads it when the process working directory is `backend` (e.g. `cd backend` before `mvnw`).
#
# Option B — Export these as OS environment variables (Docker, CI, etc.).
#
# Copy this file to .env and update the values for your environment

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/lms_elearn_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=lms_user
SPRING_DATASOURCE_PASSWORD=lms_password

# Server Configuration
SERVER_PORT=8080

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
# The secret must be base64 encoded and at least 32 bytes (256 bits) for HS256
APP_JWT_SECRET=ZmFrZV9qb3Nlc19zZWNyZXRfMzJieXRlc19iYXNlNjQ=
# JWT expiration in milliseconds (default: 86400000 = 24 hours)
APP_JWT_EXPIRATION_MS=86400000

# File Upload Configuration
FILE_UPLOAD_DIR=./uploads/course-content

# Mail Configuration
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password

# Frontend Base URL (for CORS)
APP_FRONTEND_BASE_URL=http://localhost:5173

# --- Railway (set in dashboard, not in .env.local) ---
# See backend/railway.env.example — SPRING_DATASOURCE_* from MySQL service references

